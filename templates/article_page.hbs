{{!-- ── ARTICLE HEADER ──────────────────────────────────────────── --}}
<div class="rm-article-header">
  <div class="container">
    {{breadcrumbs}}

    <h1 class="rm-article-header__title">
      {{#if article.internal}}
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" focusable="false" viewBox="0 0 16 16" class="icon-lock" title="{{t 'internal'}}">
          <rect width="12" height="9" x="2" y="7" fill="currentColor" rx="1" ry="1"/>
          <path fill="none" stroke="currentColor" d="M4.5 7.5V4a3.5 3.5 0 017 0v3.5"/>
        </svg>
      {{/if}}
      {{article.title}}
    </h1>

    {{!-- License badges --}}
    {{#if article.labels}}
      <div class="required-licenses-container">
        {{#each (filter article.labels on="identifier" starts_with="lic_")}}
          {{#is identifier 'lic_nolicense'}}
            <span class="required-license"><span class="required-license__label">{{dc 'sc_label_no_license'}}</span></span>
          {{/is}}
          {{#is identifier 'lic_platform'}}
            <span class="required-license"><span class="required-license__label">{{dc 'hp_-_platform'}}</span></span>
          {{/is}}
          {{#is identifier 'lic_equipmentTracking'}}
            <span class="required-license"><span class="required-license__label">{{dc 'hp_-_equipment_tracking'}}</span><span class="required-license__tiers"><span>Add-on</span></span></span>
          {{/is}}
          {{#is identifier 'lic_warehouse'}}
            <span class="required-license"><span class="required-license__label">{{dc 'hp_-_additional_warehouse'}}</span><span class="required-license__tiers"><span>Add-on</span></span></span>
          {{/is}}
          {{#is identifier 'lic_qouteInvoice'}}
            <span class="required-license"><span class="required-license__label">{{dc 'hp_-_quoting_invoicing'}}</span><span class="required-license__tiers"><span>Add-on</span></span></span>
          {{/is}}
          {{#contains (concat 'lic_equipmentSchedule_S' 'lic_equipmentSchedule_P') identifier}}
            <span class="required-license"><span class="required-license__label">{{dc 'hp_-_equipmentscheduling'}}</span><span class="required-license__tiers">{{#is identifier 'lic_equipmentSchedule_S'}}<span>Standard</span>{{/is}}{{#contains (concat 'lic_equipmentSchedule_S' 'lic_equipmentSchedule_P') identifier}}<span>Pro</span>{{/contains}}</span></span>
          {{/contains}}
          {{#contains (concat 'lic_crew_E' 'lic_crew_S' 'lic_crew_P') identifier}}
            <span class="required-license"><span class="required-license__label">{{dc 'hp_-_crew_scheduling'}}</span><span class="required-license__tiers">{{#is identifier 'lic_crew_E'}}<span>Essential</span>{{/is}}{{#contains (concat 'lic_crew_E' 'lic_crew_S') identifier}}<span>Standard</span>{{/contains}}{{#contains (concat 'lic_crew_E' 'lic_crew_S' 'lic_crew_P') identifier}}<span>Pro</span>{{/contains}}</span></span>
          {{/contains}}
        {{/each}}
      </div>
    {{/if}}

    {{!-- Meta line --}}
    <div class="rm-article-header__meta">
      <div class="meta-group">
        {{#is article.created_at article.edited_at}}
          <span class="meta-data">{{date article.created_at timeago=true}}</span>
        {{else}}
          <span class="meta-data">{{t 'updated'}}</span>
          <span class="meta-data">{{date article.edited_at timeago=true}}</span>
        {{/is}}
      </div>
    </div>
  </div>
</div>

{{!-- ── ARTICLE BODY ─────────────────────────────────────────────── --}}
<div class="container rm-article-container" id="article-container" data-article-page>
  <div class="rm-article-layout">

    {{!-- Main content --}}
    <article id="main-content" class="article rm-article-main" data-article>
      <section class="article-info">
        <div class="article-content">

          <div class="article-body">{{article.body}}</div>

          {{!-- Attachments --}}
          {{#if attachments}}
            <div class="rm-article-attachments">
              <p class="rm-article-attachments__label">Attachments</p>
              <ul class="attachments">
                {{#each attachments}}
                  <li class="attachment-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" focusable="false" viewBox="0 0 16 16" class="attachment-icon">
                      <path fill="none" stroke="currentColor" stroke-linecap="round" d="M9.5 4v7.7c0 .8-.7 1.5-1.5 1.5s-1.5-.7-1.5-1.5V3C6.5 1.6 7.6.5 9 .5s2.5 1.1 2.5 2.5v9c0 1.9-1.6 3.5-3.5 3.5S4.5 13.9 4.5 12V4"/>
                    </svg>
                    <a href="{{url}}" target="_blank">{{name}}</a>
                    <div class="attachment-meta meta-group">
                      <span class="attachment-meta-item meta-data">{{size}}</span>
                      <a href="{{url}}" target="_blank" class="attachment-meta-item meta-data">{{t 'download'}}</a>
                    </div>
                  </li>
                {{/each}}
              </ul>
            </div>
          {{/if}}

          {{!-- Voting + Swifteq feedback --}}
          {{#with article}}
          <div class="article-votes rm-article-votes" id="article-votes">
            <span class="article-votes-question" id="article-votes-label">{{t 'was_this_article_helpful'}}</span>
            <div class="article-votes-controls" role="group" aria-labelledby="article-votes-label">
              {{vote 'up' role='radio' class='button article-vote article-vote-up' selected_class="button-primary"}}
              {{vote 'down' id='down-vvote-id' role='radio' class='button article-vote article-vote-down' selected_class="button-primary"}}
            </div>
            <small class="article-votes-count">
              {{vote 'label' class='article-vote-label'}}
            </small>
            <div id="sq-article-feedback-form" style="padding-top: 12px; display: none;">
              <div id="sq-article-feedback-prompt" style="text-align: center; margin-top: 12px; margin-bottom: 24px; font-weight: 600">
                <div id="sq-article-feedback-prompt-down" style="display: none">We're sorry to hear that. Can you tell us what went wrong?</div>
                <div id="sq-article-feedback-prompt-up" style="display: none">We're glad we could help! Is there anything you'd like to share with us?</div>
              </div>
              <div id="sq-article-feedback-options" style="text-align: left; margin-bottom: 18px">
                <div id="sq-article-feedback-options-down" style="text-align: left; margin-bottom: 18px; display: none">
                  <div style="margin-bottom: 6px"><input type="radio" id="sq-article-feedback-options-down-1" name="sq-article-feedback-options-down" value="1"/><label for="sq-article-feedback-options-down-1" style="margin-left: 5px">This article didn't answer my question or solve my problem</label></div>
                  <div style="margin-bottom: 6px"><input type="radio" id="sq-article-feedback-options-down-2" name="sq-article-feedback-options-down" value="2"/><label for="sq-article-feedback-options-down-2" style="margin-left: 5px">I found this article confusing or difficult to read</label></div>
                  <div style="margin-bottom: 6px"><input type="radio" id="sq-article-feedback-options-down-3" name="sq-article-feedback-options-down" value="3"/><label for="sq-article-feedback-options-down-3" style="margin-left: 5px">I don't like the answer I found or how the feature works</label></div>
                  <div style="margin-bottom: 6px"><input type="radio" id="sq-article-feedback-options-down-4" name="sq-article-feedback-options-down" value="4"/><label for="sq-article-feedback-options-down-4" style="margin-left: 5px">Something else</label></div>
                </div>
                <div id="sq-article-feedback-options-up" style="text-align: left; margin-bottom: 18px; display: none"></div>
              </div>
              <div id="sq-article-feedback-text" style="text-align: left">
                <textarea id="sq-article-feedback-text-up" placeholder="Please provide any feedback you'd like to share" name="article-down-vote-reason" rows="4" cols="50" style="display: none"></textarea>
                <textarea id="sq-article-feedback-text-down" placeholder="Please provide any feedback you'd like to share" name="article-down-vote-reason" rows="4" cols="50" style="display: none"></textarea>
                <div id="sq-article-feedback-note-up" style="font-size: small; color: grey">This form is for feedback only and you won't receive a reply. Please don't include any personal information about yourself or someone else.</div>
                <div id="sq-article-feedback-note-down" style="font-size: small; color: grey">This form is for feedback only and you won't receive a reply. Please don't include any personal information about yourself or someone else.</div>
                <button id="sq-article-submit-feedback" class="button button-primary" style="margin-top: 12px;">Submit Feedback</button>
              </div>
              <div id="sq-article-feedback-confirm-up" style="display: none; color: green; margin-top: 10px">Thank you! Your feedback helps us improve this article for everyone.</div>
              <div id="sq-article-feedback-confirm-down" style="display: none; color: green; margin-top: 10px">Thank you! Your feedback helps us improve this article for everyone.</div>
            </div>
          </div>
          {{/with}}

        </div>{{!-- /.article-content --}}
      </section>{{!-- /.article-info --}}

{{!-- Related articles --}}
      {{#if settings.show_related_articles}}
        <div class="rm-article-related">
          {{related_articles}}
        </div>
      {{/if}}

      {{!-- Recently viewed --}}
      {{#if settings.show_recently_viewed_articles}}
        <div class="rm-article-recent">
          {{recent_articles}}
        </div>
      {{/if}}

    </article>

    {{!-- Sidebar: articles in section --}}
    {{#if settings.show_articles_in_section}}
      <aside class="rm-article-sidebar" aria-label="Articles in this section">
        <div class="rm-article-sidebar__inner">
          <p class="rm-article-sidebar__title">In this section</p>
          <ul class="rm-article-sidebar__list">
            {{#each section.articles}}
              <li class="rm-article-sidebar__item {{#is id ../article.id}}is-current{{/is}}">
                <a href="{{url}}" class="rm-article-sidebar__link" {{#is id ../article.id}}aria-current="page"{{/is}}>{{title}}</a>
              </li>
            {{/each}}
          </ul>
          {{#if section.more_articles}}
            <a href="{{section.url}}" class="rm-article-sidebar__more">See all articles →</a>
          {{/if}}
        </div>
        <a href="#article-container" class="rm-article-sidebar__top">↑ Return to top</a>
      </aside>
    {{/if}}

  </div>
</div>
